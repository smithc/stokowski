# Linear API key — required for issue polling and state management
LINEAR_API_KEY=<YOUR_LINEAR_API_KEY>

# GitHub personal access token — used for git credential helper and gh CLI
GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>

# Claude Code OAuth token — required for Docker mode (containers can't use interactive login)
# Generate via: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=<YOUR_CLAUDE_CODE_OAUTH_TOKEN>
